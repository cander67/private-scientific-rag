# Copy to .env for local overrides. Do not commit .env.

PRIVATE_RAG_ENV=local
PRIVATE_RAG_DATA_DIR=./data
PRIVATE_RAG_DATABASE_URL=sqlite:///./data/private_rag.sqlite

PRIVATE_RAG_API_HOST=127.0.0.1
PRIVATE_RAG_API_PORT=8000
PRIVATE_RAG_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

PRIVATE_RAG_QDRANT_URL=http://localhost:6333

# Local Ollama runtime used for chat models and Ollama embedding models.
PRIVATE_RAG_OLLAMA_BASE_URL=http://localhost:11434
PRIVATE_RAG_DEFAULT_LLM=gemma3:4b

# Repository settings remain the source of truth for a repository's active embedding
# provider/model. This default seeds new repositories.
PRIVATE_RAG_DEFAULT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
PRIVATE_RAG_DEFAULT_RERANKER=cross-encoder/ms-marco-MiniLM-L6-v2
