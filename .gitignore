# Python bytecode (compiled Python files)
__pycache__/
*.py[cod]
*.so

# Distribution/packaging
*.egg-info/
dist/
wheels/
build/

# Virtual environments (huge, recreatable)
venv/
.venv/
env/
.env
*.env
!.env.example

# Testing artifacts
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
coverage.xml
.uv-cache/

# IDE settings (personal preferences)
.vscode/
.idea/
*.swp

# OS files (irrelevant to project)
.DS_Store
Thumbs.db

# Local Codex/agent configuration and generated metadata.
.codex/

# Project-specific
# Inspiration/prototype code. Keep locally, do not commit.
example_code/

# Local runtime data, generated indexes, exports, and models.
data/
models/
exports/
logs/
cache/
.qdrant/

# Private document corpora. Keep sample fixtures under tests/ instead.
documents/
!documents/README.md

# Frontend dependency/build outputs.
/node_modules/
/package-lock.json
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts

# Local planning drafts that are not part of the public repo.
.plans/
