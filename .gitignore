# Python bytecode (compiled Python files)
__pycache__/
*.py[cod]
*.so

# Distribution/packaging
*.egg-info/
dist/
wheels/
build/

# Virtual environments (huge, recreatable)
venv/
.venv/
env/
.env
*.env
!.env.example

# Testing artifacts
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
coverage.xml
.uv-cache/
tmp/

# IDE settings (personal preferences)
.vscode/
.idea/
*.swp

# OS files (irrelevant to project)
.DS_Store
Thumbs.db

# Local agent configuration and generated metadata.
.codex/
.claude/

# Project-specific
# Inspiration/prototype code. Keep locally, do not commit.
example_code/

# Local runtime data, generated indexes, exports, and models.
data/
models/
exports/
logs/
cache/
.qdrant/

# Private document corpora. Keep source documents and personal helper scripts
# out of Git, but allow public-safe documentation, manifests, checks, notes,
# and structure markers.
documents/*
documents/*.local.sh
!documents/README.md
!documents/golden_corpus/
documents/golden_corpus/*
!documents/golden_corpus/golden_corpus_manifest.md
!documents/golden_corpus/golden_corpus_manifest_v*.md
!documents/golden_corpus/checks/
!documents/golden_corpus/checks/*.yaml
!documents/golden_corpus/checks/*.md
!documents/golden_corpus/notes/
!documents/golden_corpus/notes/*.md
!documents/golden_corpus/patents_uploaded/
!documents/golden_corpus/patents_uploaded/README.md
!documents/golden_corpus/source_bundles/
!documents/golden_corpus/source_bundles/.gitkeep
!documents/golden_corpus/text/
!documents/golden_corpus/text/.gitkeep

# Frontend dependency/build outputs.
/node_modules/
/package-lock.json
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts

# Mockup tooling outputs (Playwright). Screenshots are regenerated, not committed.
mockups/node_modules/
mockups/package-lock.json
mockups/screenshots/
mockups/test-results/
mockups/playwright-report/

# Local planning drafts that are not part of the public repo.
.plans/
